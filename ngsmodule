#!/usr/bin/env bash
# shellcheck shell=bash
###############################################################################
# ngsmodule — framework-style CLI dispatcher
#
# Auto-discovers pipelines under `pipelines/core/<name>/pipeline.sh` (each
# with a `meta.yml`) and exposes them as subcommands. Drop a new directory
# into `pipelines/core/` and it appears here automatically.
#
# Backwards compatibility: the legacy `./NGSmodule` entry point is preserved
# untouched. Use `./ngsmodule` (lowercase) for the new dispatcher.
#
# Usage:
#   ./ngsmodule list                                  – show available pipelines
#   ./ngsmodule run <pipeline> -c <ConfigFile> [opts] – run a pipeline
#   ./ngsmodule info <pipeline>                       – show metadata
#   ./ngsmodule help [<pipeline>]                     – show usage
#
# Common flags:
#   --dry-run        echo commands instead of running them
#   --strict         enable `set -euo pipefail` inside step scripts
#   --force          re-run samples that are already marked complete
#   --retry N        per-sample retry count (default 1)
#   --ntask N|ALL    parallelism hint (default 1)
###############################################################################

set -euo pipefail

NGSMODULE_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
PIPELINES_DIR="$NGSMODULE_ROOT/pipelines/core"

# shellcheck source=pipelines/lib/runtime.sh
source "$NGSMODULE_ROOT/pipelines/lib/runtime.sh"

usage() {
  cat <<EOF
ngsmodule — sample-first NGS pipeline framework

USAGE
  ngsmodule <command> [options]

COMMANDS
  list                                List discovered pipelines
  info <pipeline>                     Show metadata for a pipeline
  version                             Show framework version + pipeline/module manifest
  init <name> [--scope sample|project] [--requires a,b]
                                      Scaffold a new pipeline directory under pipelines/core/
  deps <pipeline>                     Print prerequisite graph (preview what 'run' would resolve)
  run <pipeline> [opts]               Execute a pipeline (auto-resolves prerequisites)
  resume <pipeline> -c <ConfigFile>   Re-run only failed/incomplete samples for a pipeline
  clean [<pipeline>] -c <ConfigFile> [--filter <regex>] [--yes]
                                      Wipe .state.json files (or just one stage from each)
  status -c <ConfigFile>              Show sample × stage grid for a project
  trace <sample> [-c <ConfigFile>]    Show lineage of a sample's outputs
  report -c <ConfigFile> [-o file]    Render self-contained HTML report
  test [<pipeline>] [--real]          Run the bundled test fixtures (dry-run by default)
  lint [<pipeline>]                   Validate one (or all) pipelines' meta.yml + schema
  help [<pipeline>]                   Show this message or pipeline-specific help

GLOBAL FLAGS (apply to 'run')
  -c, --config <file>        Path to a ConfigFile (sourced into the env)
  -s, --samples <csv>        Path to SampleInfoFile (overrides ConfigFile)
      --dry-run              Preview commands; emit ::dry-run:: events
      --strict               Enable set -euo pipefail in step scripts
      --force                Re-run samples even if already complete
      --no-deps              Skip auto-resolution of prerequisite pipelines
      --retry <N>            Per-sample retry count (default 1)
      --ntask <N|ALL>        Concurrency hint (default 1)
      --rawdata <dir>        Override rawdata_dir from config
      --workdir <dir>        Override work_dir from config
      --profile <name>       Execution profile (local|slurm|sge|lsf, default local)
      --filter <regex>       Run only samples whose ID matches the regex
                             (e.g. "sample_4[0-9]" runs sample_40 .. sample_49)

EXAMPLES
  ngsmodule list
  ngsmodule info Alignment
  ngsmodule run preAlignmentQC -c configs/Project_X.sh
  ngsmodule run Alignment      -c configs/Project_X.sh    # auto-runs preAlignmentQC
  ngsmodule run Alignment      -c configs/Project_X.sh --no-deps
  ngsmodule status             -c configs/Project_X.sh
  ngsmodule trace Tumor_S01    -c configs/Project_X.sh
EOF
}

discover_pipelines() {
  local d
  for d in "$PIPELINES_DIR"/*/; do
    [[ -f "$d/pipeline.sh" ]] || continue
    [[ -f "$d/meta.yml" ]]    || continue
    basename "$d"
  done
}

cmd_list() {
  printf '%-25s %-25s %s\n' "NAME" "CATEGORY" "DESCRIPTION"
  printf '%-25s %-25s %s\n' "----" "--------" "-----------"
  local p
  for p in $(discover_pipelines); do
    local meta="$PIPELINES_DIR/$p/meta.yml"
    local name category desc
    name=$(grep -E '^name:' "$meta" | head -1 | sed 's/^name:[[:space:]]*//')
    category=$(grep -E '^category:' "$meta" | head -1 | sed 's/^category:[[:space:]]*//')
    desc=$(awk '/^description:/{flag=1;next}/^[a-z_]+:/{flag=0}flag' "$meta" \
             | tr -s ' \n' ' ' | sed 's/^ *//;s/ *$//' | cut -c1-60)
    printf '%-25s %-25s %s\n' "${name:-$p}" "${category:--}" "${desc:--}"
  done
}

cmd_info() {
  if [[ -z "${1:-}" ]]; then
    echo "ERROR: ngsmodule info: pipeline name required" >&2
    return 2
  fi
  local pipeline="$1"
  local meta="$PIPELINES_DIR/$pipeline/meta.yml"
  if [[ ! -f "$meta" ]]; then
    echo "ERROR: unknown pipeline: $pipeline" >&2
    echo "Run 'ngsmodule list' to see available pipelines." >&2
    return 1
  fi
  cat "$meta"
}

cmd_run() {
  if [[ -z "${1:-}" ]]; then
    echo "ERROR: ngsmodule run: pipeline name required" >&2
    return 2
  fi
  local pipeline="$1"; shift
  local script="$PIPELINES_DIR/$pipeline/pipeline.sh"
  if [[ ! -f "$script" ]]; then
    echo "ERROR: unknown pipeline: $pipeline" >&2
    echo "Run 'ngsmodule list' to see available pipelines." >&2
    return 1
  fi

  # Parse generic flags. We let the pipeline source ConfigFile itself,
  # so we just set environment variables before invocation.
  local config="" samples_csv="" rawdata_override="" workdir_override=""
  local force_flag="FALSE" retry_count="1" ntask_hint=""
  local sample_filter=""
  while (( $# > 0 )); do
    case "$1" in
      -c|--config)   config="$2"; shift 2 ;;
      -s|--samples)  samples_csv="$2"; shift 2 ;;
      --dry-run)     export NGS_DRY_RUN=1; shift ;;
      --strict)      export NGS_STRICT=1; shift ;;
      --force)       force_flag="TRUE"; shift ;;
      --retry)       retry_count="$2"; shift 2 ;;
      --ntask)       ntask_hint="$2"; shift 2 ;;
      --rawdata)     rawdata_override="$2"; shift 2 ;;
      --workdir)     workdir_override="$2"; shift 2 ;;
      --no-deps)     export NGS_NO_DEPS=1; shift ;;
      --profile)     export NGS_PROFILE="$2"; shift 2 ;;
      --filter)      sample_filter="$2"; shift 2 ;;
      -h|--help)     cmd_info "$pipeline"; return 0 ;;
      *)             echo "Unknown flag: $1" >&2; return 2 ;;
    esac
  done

  if [[ -n "$config" ]]; then
    [[ -f "$config" ]] || { echo "ERROR: config not found: $config" >&2; return 1; }
    export ConfigFile="$config"
  fi
  if [[ -n "$samples_csv" ]]; then
    export SampleInfoFile="$samples_csv"
  fi
  [[ -n "$rawdata_override" ]] && export rawdata_dir="$rawdata_override"
  [[ -n "$workdir_override" ]] && export work_dir="$workdir_override"
  [[ -n "$sample_filter"    ]] && export NGS_SAMPLE_FILTER="$sample_filter"
  export force="$force_flag"
  export retry="$retry_count"
  [[ -n "$ntask_hint" ]] && export ntask_per_run="$ntask_hint"

  log_info "ngsmodule run: pipeline=$pipeline"
  bash "$script"
}

# ---------------------------------------------------------------------------
# Resolve work_dir from a ConfigFile path. Used by `status` and `trace`.
# ---------------------------------------------------------------------------
_resolve_workdir_from_config() {
  local cfg="$1"
  [[ -z "$cfg" || ! -f "$cfg" ]] && { echo "ERROR: --config required" >&2; return 1; }
  # shellcheck source=/dev/null
  ( source "$cfg"; printf '%s' "${work_dir:-}" )
}

# ---------------------------------------------------------------------------
# `ngsmodule status` — sample × stage grid view of a project's progress.
#
# Reads each sample's .state.json and renders an aligned table where:
#   ✓ = completed
#   …  = running
#   ✗ = failed
#   ·  = pending / not yet attempted
# ---------------------------------------------------------------------------
cmd_status() {
  local config=""
  while (( $# > 0 )); do
    case "$1" in
      -c|--config) config="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  local workdir
  workdir="$(_resolve_workdir_from_config "$config")" || return 1
  if [[ -z "$workdir" || ! -d "$workdir" ]]; then
    echo "ERROR: work_dir not found (resolved: '$workdir')" >&2
    return 1
  fi

  if ! command -v jq >/dev/null 2>&1; then
    echo "ERROR: jq required for ngsmodule status" >&2
    return 1
  fi

  # Collect every state.json under workdir.
  local -a state_files=()
  while IFS= read -r f; do state_files+=("$f"); done < <(
    find "$workdir" -maxdepth 2 -name '.state.json' -type f 2>/dev/null | sort
  )
  if (( ${#state_files[@]} == 0 )); then
    echo "No samples found under $workdir (no .state.json files)."
    return 0
  fi

  # Collect every distinct stage observed across all sample state files.
  local -a stages=()
  local f stage
  while IFS= read -r stage; do
    [[ -z "$stage" ]] && continue
    case " ${stages[*]} " in *" $stage "*) ;; *) stages+=("$stage") ;; esac
  done < <(
    for f in "${state_files[@]}"; do
      jq -r '.stages | keys[]?' "$f" 2>/dev/null
    done
  )
  if (( ${#stages[@]} == 0 )); then
    echo "Samples found but no stages have run yet."
    for f in "${state_files[@]}"; do
      jq -r '.sample_id' "$f"
    done
    return 0
  fi

  # Header
  printf '%-22s' "SAMPLE"
  for stage in "${stages[@]}"; do
    printf ' %-18s' "$stage"
  done
  printf '\n'
  printf '%-22s' "------"
  for stage in "${stages[@]}"; do
    printf ' %-18s' "------------------"
  done
  printf '\n'

  # Rows
  local sid status_for elapsed
  for f in "${state_files[@]}"; do
    sid="$(jq -r '.sample_id' "$f")"
    printf '%-22s' "$sid"
    for stage in "${stages[@]}"; do
      status_for="$(jq -r --arg k "$stage" '.stages[$k].status // "·"' "$f")"
      elapsed="$(jq -r --arg k "$stage" '.stages[$k].elapsed_seconds // ""' "$f")"
      local cell
      case "$status_for" in
        completed) cell="✓ ${elapsed:+${elapsed}s}" ;;
        running)   cell="… running" ;;
        failed)    cell="✗ failed" ;;
        ·|missing|"") cell="·" ;;
        *)         cell="$status_for" ;;
      esac
      printf ' %-18s' "$cell"
    done
    printf '\n'
  done
}

# ---------------------------------------------------------------------------
# `ngsmodule trace <sample>` — dump a sample's full lineage (every stage's
# inputs, outputs, tools, and elapsed time) so you can answer "where did
# this BAM come from?" without grepping logs.
# ---------------------------------------------------------------------------
cmd_trace() {
  if [[ -z "${1:-}" ]]; then
    echo "ERROR: ngsmodule trace: sample required" >&2
    return 2
  fi
  local sample="$1"; shift
  local config=""
  while (( $# > 0 )); do
    case "$1" in
      -c|--config) config="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  local workdir
  workdir="$(_resolve_workdir_from_config "$config")" || return 1
  local state="$workdir/$sample/.state.json"
  if [[ ! -f "$state" ]]; then
    echo "ERROR: no state for $sample under $workdir" >&2
    return 1
  fi
  if ! command -v jq >/dev/null 2>&1; then
    echo "WARN: jq not found — printing raw state.json (install jq for formatted lineage)" >&2
    cat "$state"
    return 0
  fi

  jq -r '
    "Sample:    " + .sample_id,
    "Layout:    " + (.layout // "?"),
    "Group:     " + (.group // "?"),
    "Created:   " + (.created_at // "?"),
    "",
    (.stages | to_entries[] | (
      "── " + .key + " (" + (.value.status // "?") + ", " + ((.value.elapsed_seconds // "?")|tostring) + "s)",
      "   started:    " + (.value.started_at   // "?"),
      "   completed:  " + (.value.completed_at // "?"),
      "   tools:      " + ((.value.tools // []) | map(.name + "@" + (.version // "?")) | join(", ")),
      "   params:     " + ((.value.params // {}) | tojson),
      "   inputs:",
      ((.value.inputs  // []) | .[] | "     • " + .path + "  sha256=" + (.sha256 // "?")[0:12]),
      "   outputs:",
      ((.value.outputs // []) | .[] | "     • " + .path + "  sha256=" + (.sha256 // "?")[0:12]),
      ""
    ))
  ' "$state"
}

# ---------------------------------------------------------------------------
# `ngsmodule report -c <config> [-o <path>]` — render a self-contained HTML
# report of a project's run state. No external CDNs; opens offline; share
# by email or attach to a paper. Inspired by Snakemake `--report` and
# Nextflow's `report.html`, but framed around our sample × stage model.
# ---------------------------------------------------------------------------
cmd_report() {
  local config="" out=""
  while (( $# > 0 )); do
    case "$1" in
      -c|--config) config="$2"; shift 2 ;;
      -o|--output) out="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  local workdir
  workdir="$(_resolve_workdir_from_config "$config")" || return 1
  if [[ -z "$workdir" || ! -d "$workdir" ]]; then
    echo "ERROR: work_dir not found (resolved: '$workdir')" >&2
    return 1
  fi
  if ! command -v jq >/dev/null 2>&1; then
    echo "ERROR: jq required for ngsmodule report" >&2
    return 1
  fi
  out="${out:-$workdir/ngsmodule-report.html}"

  local -a state_files=()
  while IFS= read -r f; do state_files+=("$f"); done < <(
    find "$workdir" -maxdepth 2 -name '.state.json' -type f 2>/dev/null | sort
  )
  if (( ${#state_files[@]} == 0 )); then
    echo "No samples found under $workdir." >&2
    return 1
  fi

  # Aggregate every per-sample state.json into one object the renderer can
  # walk in a single pass. We compute the global timeline window and an
  # observed-stages list here so the HTML renderer is dumb-templating only.
  local agg
  agg="$(jq -s --arg gen "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
                --arg host "$(hostname 2>/dev/null || echo unknown)" \
                --arg user "$(id -un 2>/dev/null || echo unknown)" \
                --arg workdir "$workdir" '
    def stage_keys: [.[].stages // {} | keys[]?] | unique;
    def all_stage_records:
      [ .[] as $s
        | ($s.stages // {}) | to_entries[]
        | .value + {sample: $s.sample_id, stage: .key}
      ];
    def epoch(t): if t == null or t == "" then null
                  else (t | fromdateiso8601) end;
    {
      generated_at: $gen,
      host: $host,
      user: $user,
      workdir: $workdir,
      sample_count: length,
      samples: .,
      stages: stage_keys,
      stage_records: all_stage_records,
      summary: {
        completed: ([all_stage_records[] | select(.status == "completed")] | length),
        running:   ([all_stage_records[] | select(.status == "running")]   | length),
        failed:    ([all_stage_records[] | select(.status == "failed")]    | length),
        total_elapsed_seconds: ([all_stage_records[].elapsed_seconds // 0] | add // 0)
      },
      timeline: {
        t_min: ([all_stage_records[].started_at | select(. != null)] | map(epoch(.)) | min),
        t_max: ([all_stage_records[].completed_at, all_stage_records[].started_at | select(. != null)]
                | map(epoch(.)) | max)
      }
    }
  ' "${state_files[@]}")"

  _render_report_html "$agg" > "$out"
  log_ok "Report written: $out"
}

# Renders the HTML body. Pure jq + heredoc; no JS framework, all CSS-driven
# colour-coding so the file works offline and from `file://`.
_render_report_html() {
  local agg="$1"
  local title="NGSmodule run report"

  cat <<'HTML_HEAD'
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>NGSmodule run report</title>
<style>
  :root {
    --green: #2da44e; --red: #cf222e; --amber: #bf8700;
    --grey: #57606a; --bg: #ffffff; --border: #d0d7de; --soft: #f6f8fa;
  }
  * { box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
         margin: 0; padding: 24px; color: #1f2328; background: var(--bg); }
  h1 { font-size: 20px; margin: 0 0 4px; }
  h2 { font-size: 15px; margin: 28px 0 8px; padding-bottom: 6px;
       border-bottom: 1px solid var(--border); }
  .muted { color: var(--grey); font-size: 12px; }
  .meta { font-size: 12px; color: var(--grey); margin-bottom: 16px; }
  .pills { display: flex; gap: 12px; margin: 12px 0 4px; flex-wrap: wrap; }
  .pill { padding: 6px 12px; border: 1px solid var(--border); border-radius: 20px;
          font-size: 12px; background: var(--soft); }
  .pill .n { font-weight: 600; font-size: 14px; }
  .pill.ok    .n { color: var(--green); }
  .pill.fail  .n { color: var(--red); }
  .pill.run   .n { color: var(--amber); }
  table { border-collapse: collapse; width: 100%; font-size: 12px; }
  th, td { padding: 6px 10px; text-align: left; border-bottom: 1px solid var(--border); }
  th { background: var(--soft); font-weight: 600; }
  .grid { width: auto; }
  .grid td.cell { text-align: center; min-width: 80px; }
  .cell.completed { background: #dafbe1; color: #0a3622; }
  .cell.running   { background: #fff8c5; color: #4d2d00; }
  .cell.failed    { background: #ffebe9; color: #6e1320; }
  .cell.pending   { background: var(--soft); color: var(--grey); }
  /* Project-scope row: subtle distinct background + bold sample-id label */
  tr.row-project td:first-child { font-weight: 600; color: #0969da; }
  tr.row-project { background: #ddf4ff66; }
  .badge-project { display: inline-block; font-size: 10px; padding: 1px 6px;
                   margin-left: 6px; background: #0969da; color: white;
                   border-radius: 8px; vertical-align: middle; }
  .gantt { position: relative; height: 18px; background: var(--soft);
           border: 1px solid var(--border); border-radius: 3px; }
  .gantt .bar { position: absolute; top: 1px; bottom: 1px;
                border-radius: 2px; opacity: 0.85; }
  .bar.completed { background: var(--green); }
  .bar.running   { background: var(--amber); }
  .bar.failed    { background: var(--red); }
  details { margin: 6px 0; }
  details summary { cursor: pointer; padding: 4px; }
  pre { background: var(--soft); padding: 10px; border-radius: 4px;
        overflow: auto; font-size: 11px; }
  code { font-family: ui-monospace, "SF Mono", Menlo, monospace; }
  .small { font-size: 11px; color: var(--grey); }
</style>
</head>
<body>
HTML_HEAD

  echo '<h1>NGSmodule — run report</h1>'

  jq -r '
    "<div class=\"meta\">Generated " + .generated_at + " on " + .host
    + " by " + .user + " · workdir <code>" + .workdir + "</code></div>"
  ' <<<"$agg"

  jq -r '
    ([.samples[] | select(.sample_id != "_project")] | length) as $n_real
    | (any(.samples[]; .sample_id == "_project")) as $has_project
    | "<div class=\"pills\">"
    + "<div class=\"pill\"><span class=\"n\">" + ($n_real|tostring) + "</span> samples</div>"
    + (if $has_project then "<div class=\"pill\"><span class=\"n\">1</span> project<span class=\"badge-project\">scope</span></div>"
       else "" end)
    + "<div class=\"pill\"><span class=\"n\">" + (.stages|length|tostring) + "</span> stages</div>"
    + "<div class=\"pill ok\"><span class=\"n\">" + (.summary.completed|tostring) + "</span> completed</div>"
    + "<div class=\"pill run\"><span class=\"n\">" + (.summary.running|tostring) + "</span> running</div>"
    + "<div class=\"pill fail\"><span class=\"n\">" + (.summary.failed|tostring) + "</span> failed</div>"
    + "<div class=\"pill\"><span class=\"n\">" + (.summary.total_elapsed_seconds|tostring) + "s</span> total compute</div>"
    + "</div>"
  ' <<<"$agg"

  echo '<h2>Status grid</h2>'
  jq -r '
    . as $root
    | "<table class=\"grid\"><thead><tr><th>Sample</th>"
      + ([.stages[] | "<th>" + . + "</th>"] | join(""))
      + "</tr></thead><tbody>"
      + ([
          .samples[] as $s |
          ($s.sample_id == "_project") as $is_proj |
          "<tr" + (if $is_proj then " class=\"row-project\"" else "" end) + ">"
          + "<td>" + (if $is_proj then "Project (cohort)<span class=\"badge-project\">project</span>"
                      else $s.sample_id end) + "</td>"
          + ([
              $root.stages[] as $stg |
              ($s.stages[$stg] // {status:"pending"}) as $rec |
              "<td class=\"cell " + ($rec.status // "pending") + "\">"
              + (if $rec.status == "completed" then
                   "✓ " + (($rec.elapsed_seconds // 0)|tostring) + "s"
                 elif $rec.status == "running" then "… running"
                 elif $rec.status == "failed"  then "✗ failed"
                 else "·" end)
              + "</td>"
            ] | join(""))
          + "</tr>"
        ] | join(""))
      + "</tbody></table>"
  ' <<<"$agg"

  echo '<h2>Timeline</h2>'
  jq -r '
    . as $root
    | (.timeline.t_min // 0) as $t0
    | (.timeline.t_max // ($t0 + 1)) as $t1
    | (if $t1 > $t0 then ($t1 - $t0) else 1 end) as $span
    | def epoch(t): if t == null or t == "" then null
                    else (t | fromdateiso8601) end;
    "<table><thead><tr><th>Sample</th><th>Stage</th><th style=\"width:50%\">Time</th><th>Elapsed</th></tr></thead><tbody>"
    + ([
        .stage_records[] |
        . as $r |
        (epoch(.started_at)   // $t0) as $a |
        (epoch(.completed_at) // $a)  as $b |
        ((($a - $t0) / $span * 100)) as $left |
        ((($b - $a) / $span * 100)) as $width |
        "<tr><td>" + .sample + "</td><td>" + .stage + "</td>"
        + "<td><div class=\"gantt\"><div class=\"bar " + (.status // "pending") + "\""
        + " style=\"left:" + ($left|tostring) + "%;width:"
        + (if $width < 0.4 then 0.4 else $width end | tostring) + "%\"></div></div></td>"
        + "<td>" + ((.elapsed_seconds // 0)|tostring) + "s</td></tr>"
      ] | join(""))
    + "</tbody></table>"
  ' <<<"$agg"

  # Resource peaks across all stages with benchmark data. Sorted by max RSS so
  # users land on the biggest memory consumers first when triaging cluster jobs.
  echo '<h2>Resource usage (peak per stage)</h2>'
  jq -r '
    [ .stage_records[]
      | select(.benchmark != null and .benchmark != {})
      | { sample, stage,
          rss: (.benchmark.max_rss_kb // 0),
          cpu: (.benchmark.cpu_pct // 0),
          wall: (.benchmark.wall_seconds // .elapsed_seconds // 0) }
    ] as $rows
    | if ($rows | length) == 0 then
        "<p class=\"small\">No benchmark data captured (install <code>/usr/bin/time</code> for resource tracking).</p>"
      else
        ($rows | map(.rss) | max // 1) as $rss_max
        | "<table><thead><tr><th>Sample</th><th>Stage</th><th>Max RSS</th><th style=\"width:30%\">RSS bar</th><th>CPU%</th><th>Wall</th></tr></thead><tbody>"
          + (($rows | sort_by(-.rss))[:50]
             | map(
                 "<tr><td>" + .sample + "</td><td>" + .stage + "</td>"
                 + "<td>" + (if .rss == 0 then "—"
                              else (((.rss / 1024) * 10 | floor) / 10 | tostring) + " MB" end) + "</td>"
                 + "<td><div class=\"gantt\"><div class=\"bar completed\" style=\"left:0;width:"
                   + (if $rss_max == 0 then 0 else (.rss / $rss_max * 100) end | tostring)
                   + "%\"></div></div></td>"
                 + "<td>" + (if .cpu == 0 then "—" else (.cpu|tostring) + "%" end) + "</td>"
                 + "<td>" + (.wall|tostring) + "s</td></tr>"
               ) | join(""))
          + "</tbody></table>"
      end
  ' <<<"$agg"

  # Tool tally — which binaries were actually invoked (deduped).
  echo '<h2>Tools invoked</h2>'
  jq -r '
    [ .stage_records[]
      | select(.tools != null)
      | .tools[]?
      | (.name // .)
    ] as $tools
    | if ($tools | length) == 0 then
        "<p class=\"small\">No tool tracking data found.</p>"
      else
        ($tools | group_by(.) | map({tool: .[0], count: length}) | sort_by(-.count)) as $tally
        | "<div class=\"pills\">"
          + ($tally | map("<div class=\"pill\"><span class=\"n\">" + (.count|tostring) + "</span> " + .tool + "</div>") | join(""))
          + "</div>"
      end
  ' <<<"$agg"

  # Surface failures separately so they don't get lost in the lineage drawer.
  echo '<h2>Failures</h2>'
  jq -r '
    [.stage_records[] | select(.status == "failed")] as $fails
    | if ($fails | length) == 0 then
        "<p class=\"small\">No failed stages — clean run.</p>"
      else
        "<table><thead><tr><th>Sample</th><th>Stage</th><th>Error</th><th>Started</th></tr></thead><tbody>"
        + ($fails | map(
            "<tr><td>" + .sample + "</td><td>" + .stage + "</td>"
            + "<td><code>" + ((.error // "") | gsub("<"; "&lt;") | gsub(">"; "&gt;")) + "</code></td>"
            + "<td class=\"small\">" + (.started_at // "") + "</td></tr>"
          ) | join(""))
        + "</tbody></table>"
      end
  ' <<<"$agg"

  echo '<h2>Per-sample lineage</h2>'
  jq -r '
    .samples[] |
    (.sample_id == "_project") as $is_proj |
    "<details><summary><b>"
    + (if $is_proj then "Project (cohort)" else .sample_id end) + "</b>"
    + (if $is_proj then "<span class=\"badge-project\">project</span>" else "" end)
    + " — " + ((.stages // {}) | keys | length | tostring) + " stages</summary>"
    + "<pre>" + (. | tojson) + "</pre>"
    + "</details>"
  ' <<<"$agg"

  echo '<p class="small">ngsmodule report · self-contained HTML · no external CDN</p>'
  echo '</body></html>'
}

# ---------------------------------------------------------------------------
# `ngsmodule test [<pipeline>] [--real]` — run the bundled test fixtures
# under pipelines/core/<pipeline>/tests/. Defaults to --dry-run so it
# works on a stripped-down CI box without conda envs; pass --real to
# execute the actual tools (only meaningful if you've dropped real data
# into tests/test_data/).
# ---------------------------------------------------------------------------
cmd_test() {
  local pipeline="" real=0
  while (( $# > 0 )); do
    case "$1" in
      --real)  real=1; shift ;;
      -h|--help) echo "ngsmodule test [<pipeline>] [--real]"; return 0 ;;
      *)       pipeline="$1"; shift ;;
    esac
  done

  local -a pipelines
  if [[ -n "$pipeline" ]]; then
    pipelines=("$pipeline")
  else
    while IFS= read -r p; do pipelines+=("$p"); done < <(discover_pipelines)
  fi

  local total=0 passed=0 skipped=0 failed=0
  local p tdir tcfg tcsv work
  for p in "${pipelines[@]}"; do
    tdir="$PIPELINES_DIR/$p/tests"
    tcfg="$tdir/test_config.sh"
    tcsv="$tdir/test_samples.csv"
    if [[ ! -f "$tcfg" || ! -f "$tcsv" ]]; then
      printf '⊘ %-22s no tests/ fixture (skip)\n' "$p"
      skipped=$((skipped + 1))
      continue
    fi
    total=$((total + 1))
    work="/tmp/ngsmodule-test-$$/$p"
    rm -rf "$work" && mkdir -p "$work"

    printf '▶ %-22s ' "$p"
    local mode_args=()
    (( real )) || mode_args+=(--dry-run)

    if TEST_DIR="$tdir" TEST_WORK="/tmp/ngsmodule-test-$$" \
         "$NGSMODULE_ROOT/ngsmodule" run "$p" \
           -c "$tcfg" -s "$tcsv" --no-deps "${mode_args[@]}" \
           >"$work/test.log" 2>&1; then
      printf 'OK\n'
      passed=$((passed + 1))
    else
      printf 'FAIL  (see %s)\n' "$work/test.log"
      tail -15 "$work/test.log" | sed 's/^/    | /'
      failed=$((failed + 1))
    fi
  done

  printf '\n%d passed, %d failed, %d skipped (out of %d)\n' \
    "$passed" "$failed" "$skipped" "$total"
  (( failed > 0 )) && return 1
  return 0
}

# ---------------------------------------------------------------------------
# `ngsmodule lint [<pipeline>]` — quality gate for meta.yml + params_schema.
# Without arguments, lints every discovered pipeline. Exits non-zero if any
# pipeline has issues, so it's CI-friendly.
# ---------------------------------------------------------------------------
# ---------------------------------------------------------------------------
# `ngsmodule init <name>` — scaffold a new pipeline.
#
# Creates:
#   pipelines/core/<Name>/
#     meta.yml          (skeleton with TODO placeholders)
#     env.yml           (minimal conda env stub)
#     pipeline.sh       (boilerplate run_<Name>_for_{sample,project} fn)
#     tests/test_samples.csv
#     tests/test_config.sh
#     tests/test_data/.gitkeep
#
# Flags:
#   --scope project|sample   (default: sample)
#   --requires <prereq,...>  comma-separated requires: list
#   --category <cat>         (default: Custom)
#   --force                  overwrite existing scaffold
# ---------------------------------------------------------------------------
cmd_init() {
  if [[ -z "${1:-}" ]]; then
    echo "ERROR: ngsmodule init: pipeline name required" >&2
    echo "Usage: ngsmodule init <name> [--scope sample|project] [--requires a,b]" >&2
    return 2
  fi
  local name="$1"; shift

  local scope="sample" category="Custom" requires_csv="" force=0
  while (( $# > 0 )); do
    case "$1" in
      --scope)     scope="$2"; shift 2 ;;
      --requires)  requires_csv="$2"; shift 2 ;;
      --category)  category="$2"; shift 2 ;;
      --force)     force=1; shift ;;
      *) echo "Unknown flag: $1" >&2; return 2 ;;
    esac
  done

  case "$scope" in sample|project) ;; *) echo "ERROR: --scope must be sample|project (got '$scope')" >&2; return 2 ;; esac
  if ! [[ "$name" =~ ^[A-Za-z][A-Za-z0-9_]*$ ]]; then
    echo "ERROR: pipeline name must be [A-Za-z][A-Za-z0-9_]*" >&2
    return 2
  fi

  local dir="$PIPELINES_DIR/$name"
  if [[ -d "$dir" ]] && (( ! force )); then
    echo "ERROR: $dir already exists (use --force to overwrite)" >&2
    return 1
  fi
  mkdir -p "$dir/tests/test_data"
  touch "$dir/tests/test_data/.gitkeep"

  # ---- meta.yml ----
  local requires_yaml="# requires:"
  if [[ -n "$requires_csv" ]]; then
    requires_yaml="requires:"$'\n'
    local IFS=','
    local r
    for r in $requires_csv; do
      requires_yaml+="  - $r"$'\n'
    done
    # Strip trailing newline for cleaner heredoc
    requires_yaml="${requires_yaml%$'\n'}"
  fi

  local scope_yaml=""
  [[ "$scope" == "project" ]] && scope_yaml=$'\n'"scope: project"

  cat >"$dir/meta.yml" <<META
