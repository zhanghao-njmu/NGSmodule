# ---------------------------------------------------------------------------
# `ngsmodule clean [<pipeline>] -c <ConfigFile> [--filter <regex>]` —
# remove recorded state so the next `run` starts fresh.
#
# Without arguments: clears every .state.json under work_dir (cohort reset).
# With <pipeline>:   removes just that pipeline's stage entry from each
#                    .state.json (other stages keep their history).
# With --filter:     restrict the action to matching sample IDs.
# Always asks for explicit --yes confirmation since it's destructive.
# ---------------------------------------------------------------------------
cmd_clean() {
  local pipeline="" config="" filter="" yes=0
  if (( $# > 0 )) && [[ "$1" != -* ]]; then
    pipeline="$1"; shift
  fi
  while (( $# > 0 )); do
    case "$1" in
      -c|--config) config="$2"; shift 2 ;;
      --filter)    filter="$2"; shift 2 ;;
      --yes|-y)    yes=1; shift ;;
      *) echo "Unknown flag: $1" >&2; return 2 ;;
    esac
  done
  if [[ -z "$config" ]]; then
    echo "ERROR: ngsmodule clean requires -c <ConfigFile>" >&2
    return 1
  fi

  local workdir
  workdir="$(_resolve_workdir_from_config "$config")" || return 1
  if [[ -z "$workdir" || ! -d "$workdir" ]]; then
    echo "ERROR: work_dir not found (resolved: '$workdir')" >&2
    return 1
  fi
  if ! command -v jq >/dev/null 2>&1; then
    echo "ERROR: jq required for ngsmodule clean" >&2
    return 1
  fi

  local -a state_files=()
  while IFS= read -r f; do state_files+=("$f"); done < <(
    find "$workdir" -maxdepth 2 -name '.state.json' -type f 2>/dev/null | sort
  )
  if (( ${#state_files[@]} == 0 )); then
    echo "No .state.json files under $workdir."
    return 0
  fi

  # Apply --filter to narrow the file list (match on sample_id read from
  # each file rather than the parent dir name, so _project is filtered
  # out unless the regex explicitly matches "_project").
  if [[ -n "$filter" ]]; then
    local -a kept=()
    local f sid
    for f in "${state_files[@]}"; do
      sid="$(jq -r '.sample_id // .sample // ""' "$f" 2>/dev/null)"
      [[ -z "$sid" ]] && continue
      if [[ "$sid" =~ $filter ]]; then kept+=("$f"); fi
    done
    state_files=("${kept[@]}")
    if (( ${#state_files[@]} == 0 )); then
      echo "No samples match --filter '$filter'."
      return 0
    fi
  fi

  # Preview what we're about to do.
  if [[ -z "$pipeline" ]]; then
    echo "Will REMOVE ${#state_files[@]} .state.json file(s) entirely."
  else
    echo "Will remove '$pipeline' stage from ${#state_files[@]} .state.json file(s)."
  fi
  if (( ! yes )); then
    printf 'Confirm? Type yes to proceed: '
    local reply
    read -r reply
    [[ "$reply" == "yes" ]] || { echo "Aborted."; return 1; }
  fi

  local f modified=0
  for f in "${state_files[@]}"; do
    if [[ -z "$pipeline" ]]; then
      rm -f "$f" && modified=$((modified + 1))
    else
      # Drop the stage key; if no stages remain, keep the file but
      # leave .stages = {} so future runs can still reference it.
      local tmp
      tmp="$(mktemp "${f}.XXXXXX")"
      if jq --arg p "$pipeline" 'del(.stages[$p])' "$f" >"$tmp" && mv "$tmp" "$f"; then
        modified=$((modified + 1))
      else
        rm -f "$tmp"
        log_warn "failed to update $f"
      fi
    fi
  done

  log_ok "ngsmodule clean: ${modified}/${#state_files[@]} state file(s) updated"
}

# ---------------------------------------------------------------------------
# `ngsmodule version` — print framework version + manifest of all
# discovered pipelines and modules. Useful for bug reports and reproducible
# environments.
# ---------------------------------------------------------------------------
NGSMODULE_VERSION="2.0.0"
cmd_version() {
  echo "ngsmodule framework $NGSMODULE_VERSION"
  echo "  bash         $BASH_VERSION"
  echo "  jq           $(jq --version 2>/dev/null || echo "(not installed)")"
  echo "  installed at $NGSMODULE_ROOT"
  echo
  echo "Pipelines:"
  local p ver scope
  while IFS= read -r p; do
    ver="$(awk '/^version:/ {print $2; exit}' "$PIPELINES_DIR/$p/meta.yml" 2>/dev/null)"
    ver="${ver//\"/}"; ver="${ver//\'/}"
    scope="$(awk '/^scope:/ {print $2; exit}' "$PIPELINES_DIR/$p/meta.yml" 2>/dev/null)"
    scope="${scope//\"/}"; scope="${scope//\'/}"
    [[ -z "$scope" ]] && scope="sample"
    printf '  %-26s %-8s %s\n' "$p" "${ver:-?}" "[$scope]"
  done < <(discover_pipelines)
  echo
  echo "Tool modules:"
  local m
  for m in "$NGSMODULE_ROOT/pipelines/modules/"*.sh; do
    [[ "$(basename "$m")" == "_lib.sh" ]] && continue
    printf '  %s\n' "$(basename "$m" .sh)"
  done
  echo
  echo "Cluster profiles:"
  local prof
  for prof in "$NGSMODULE_ROOT/pipelines/profiles/"*.sh; do
    printf '  %s\n' "$(basename "$prof" .sh)"
  done
}

cmd_lint() {
  # shellcheck source=pipelines/lib/schema.sh
  source "$NGSMODULE_ROOT/pipelines/lib/schema.sh"
  local rc=0 p
  if (( $# > 0 )); then
    pipeline_lint "$1" || rc=$?
  else
    for p in $(discover_pipelines); do
      pipeline_lint "$p" || rc=$?
    done
  fi
  return $rc
}

# ---------------------------------------------------------------------------
# `ngsmodule resume <pipeline> -c <ConfigFile>` — re-run only the samples
# whose previous attempt at <pipeline> failed (or never completed).
#
# Implementation: discover failed/incomplete samples by reading every
# .state.json under work_dir, build a regex matching their IDs, then
# delegate to `ngsmodule run` with --filter $regex --force. Inherits
# everything else from cmd_run (--profile, --no-deps, etc.).
# ---------------------------------------------------------------------------
cmd_resume() {
  if [[ -z "${1:-}" ]]; then
    echo "ERROR: ngsmodule resume: pipeline name required" >&2
    echo "Usage: ngsmodule resume <pipeline> -c <ConfigFile>" >&2
    return 2
  fi
  local pipeline="$1"; shift

  # Pull --config out of the args so we can also resolve work_dir
  # ourselves; everything else is forwarded verbatim to `ngsmodule run`.
  local config="" forwarded=()
  while (( $# > 0 )); do
    case "$1" in
      -c|--config) config="$2"; forwarded+=("$1" "$2"); shift 2 ;;
      *)           forwarded+=("$1"); shift ;;
    esac
  done
  if [[ -z "$config" ]]; then
    echo "ERROR: ngsmodule resume requires -c <ConfigFile>" >&2
    return 1
  fi

  local workdir
  workdir="$(_resolve_workdir_from_config "$config")" || return 1
  if [[ -z "$workdir" || ! -d "$workdir" ]]; then
    echo "ERROR: work_dir not found (resolved: '$workdir')" >&2
    return 1
  fi
  if ! command -v jq >/dev/null 2>&1; then
    echo "ERROR: jq required for ngsmodule resume" >&2
    return 1
  fi

  # Walk every .state.json (excluding the _project sentinel) and pick
  # samples where the requested pipeline is failed or unrecorded.
  local -a state_files=()
  while IFS= read -r f; do state_files+=("$f"); done < <(
    find "$workdir" -maxdepth 2 -name '.state.json' -type f 2>/dev/null \
      | grep -v '/_project/' | sort
  )
  if (( ${#state_files[@]} == 0 )); then
    echo "No samples found under $workdir." >&2
    return 1
  fi

  local -a samples_to_retry=()
  local f sid status
  for f in "${state_files[@]}"; do
    sid="$(jq -r '.sample_id // .sample // ""' "$f" 2>/dev/null)"
    [[ -z "$sid" ]] && continue
    status="$(jq -r --arg p "$pipeline" '.stages[$p].status // "missing"' "$f" 2>/dev/null)"
    case "$status" in
      completed) ;;  # skip
      *)         samples_to_retry+=("$sid") ;;
    esac
  done

  if (( ${#samples_to_retry[@]} == 0 )); then
    log_ok "No samples need resuming — $pipeline is complete for every sample."
    return 0
  fi

  # Build an alternation regex: ^(s1|s2|s3)$. Escape metachars in IDs.
  local sid_alt
  sid_alt="$(printf '%s\n' "${samples_to_retry[@]}" \
    | sed -e 's/[][\\.*^$+?()|{}]/\\&/g' | paste -sd '|' -)"
  local regex="^(${sid_alt})\$"

  log_info "ngsmodule resume: $pipeline → ${#samples_to_retry[@]} sample(s) to retry"
  log_info "                  --filter '$regex' --force"

  cmd_run "$pipeline" "${forwarded[@]}" --filter "$regex" --force
}

# ---------------------------------------------------------------------------
# `ngsmodule deps <pipeline>` — print the recursive prerequisite graph for
# a pipeline. Useful to preview what `run` will actually execute.
#
# Output format: tree with " ← " separators showing dependency direction.
# The terminal pipeline is at the top; its prereqs indented below.
# ---------------------------------------------------------------------------
cmd_deps() {
  if [[ -z "${1:-}" ]]; then
    echo "ERROR: ngsmodule deps: pipeline name required" >&2
    echo "Usage: ngsmodule deps <pipeline>" >&2
    return 2
  fi
  local pipeline="$1"
  local meta="$PIPELINES_DIR/$pipeline/meta.yml"
  if [[ ! -f "$meta" ]]; then
    echo "ERROR: unknown pipeline: $pipeline" >&2
    return 1
  fi

  # Source orchestrator helpers for pipeline_requires + pipeline_scope.
  # shellcheck source=pipelines/lib/orchestrator.sh
  PIPELINES_DIR="$PIPELINES_DIR" source "$NGSMODULE_ROOT/pipelines/lib/orchestrator.sh" 2>/dev/null

  echo "Dependency graph for: $pipeline"
  echo
  _deps_render "$pipeline" 0 ""
  echo
  echo "Legend:  [project] = scope:project pipeline   [sample] = scope:sample (default)"
  echo "Run order: depth-first, leaves first. Use --no-deps to skip resolution."
}

# Print a pipeline + recursively its prereqs as an indented tree.
# Args: pipeline depth visited_csv
_deps_render() {
  local p="$1" depth="$2" visited="$3"
  local indent=""
  local i
  for (( i = 0; i < depth; i++ )); do indent+="  "; done

  local scope tag
  scope="$(pipeline_scope "$p" 2>/dev/null || echo sample)"
  tag="[$scope]"

  printf '%s- %-26s %s\n' "$indent" "$p" "$tag"

  # Detect cycles.
  case ",$visited," in *,"$p",*) printf '%s  ↳ (cycle, skipping)\n' "$indent"; return ;; esac
  visited="${visited:+$visited,}$p"

  local prereq
  while IFS= read -r prereq; do
    [[ -z "$prereq" ]] && continue
    _deps_render "$prereq" "$((depth + 1))" "$visited"
  done < <(pipeline_requires "$p" 2>/dev/null)
}

main() {
  local cmd="${1:-help}"
  case "$cmd" in
    list)       cmd_list ;;
    info)       shift; cmd_info "$@" ;;
    init)       shift; cmd_init "$@" ;;
    run)        shift; cmd_run "$@" ;;
    resume)     shift; cmd_resume "$@" ;;
    deps)       shift; cmd_deps "$@" ;;
    status)     shift; cmd_status "$@" ;;
    trace)      shift; cmd_trace "$@" ;;
    report)     shift; cmd_report "$@" ;;
    test)       shift; cmd_test "$@" ;;
    lint)       shift; cmd_lint "$@" ;;
    clean)      shift; cmd_clean "$@" ;;
    version|--version) cmd_version ;;
    help|-h|--help) shift; if [[ $# -eq 0 ]]; then usage; else cmd_info "$@"; fi ;;
    *)          usage; return 2 ;;
  esac
}

main "$@"
