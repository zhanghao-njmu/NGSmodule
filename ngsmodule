display_name: TODO — friendly name
category: $category
version: 1.0.0$scope_yaml
description: >
  TODO — one-paragraph description. The web UI shows this verbatim.
$requires_yaml
tools:
  - TODO_tool >= 1.0
default_params:
  TODO_param: default_value
# Typed schema consumed by pipelines/lib/schema.sh.
params_schema:
  TODO_param:
    type: string
    default: default_value
    description: TODO — describe this parameter.
estimated_minutes_per_sample: 30
resources:
  mem: 8G
  time: "2:00:00"
  cpus_per_task: 4
  partition: short
  queue: main
inputs:
  kind: TODO_input_kind
  pattern: "TODO_pattern"
outputs:
  - kind: TODO_output_kind
    pattern: "{sample}.TODO.out"
META

  # ---- env.yml ----
  cat >"$dir/env.yml" <<ENV
# Conda environment for the $name pipeline.

name: ngsmodule-$name
channels:
  - bioconda
  - conda-forge
dependencies:
  - python=3.11
  - jq
  # TODO: pin the bioinformatics tools your pipeline uses
ENV

  # ---- pipeline.sh ----
  local entry_fn worker_signature worker_body
  if [[ "$scope" == "project" ]]; then
    entry_fn="run_${name}_for_project"
    worker_signature="${entry_fn}() {"
    worker_body=$'  module_reset

  # TODO: read inputs (e.g. per-sample outputs from prereq pipelines)
  local out_dir="$work_dir/$NGS_PROJECT_SENTINEL/'"$name"$'"
  mkdir -p "$out_dir"

  emit_status "[_project] '"$name"$': starting"

  # TODO: do the project-level work here.
  # Use module_run "<desc>" cmd args... to wrap CLI invocations.
  # In dry-run mode, the wrapper short-circuits to a print, so your
  # pipeline code should not assume the command actually executed.

  if ! is_dry_run; then
    # TODO: emit_artifact <kind> <path> for each output you produce.
    :
  fi

  local tools_json inputs_json outputs_json params_json
  tools_json="$(module_tools_json)"
  inputs_json=\'[]\'    # TODO: populate from real inputs
  outputs_json=\'[]\'   # TODO: populate from real outputs
  params_json="$(printf \'{"TODO_param":"%s"}\' "${TODO_param:-}")"

  ngs_state_stage_end "$NGS_PROJECT_SENTINEL" '"$name"$' completed \\
    --params  "$params_json" \\
    --tools   "$tools_json" \\
    --inputs  "$inputs_json" \\
    --outputs "$outputs_json"

  return 0
}'
  else
    entry_fn="run_${name}_for_sample"
    worker_signature="${entry_fn}() {"
    worker_body=$'  local sample="${1:?sample required}"
  local sample_dir="$work_dir/$sample"
