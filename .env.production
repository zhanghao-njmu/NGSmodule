# ================================================================================
# NGSmodule Production Environment Configuration
# ================================================================================
# IMPORTANT:
# 1. Copy this file to .env in production
# 2. Replace ALL placeholder values with actual production values
# 3. NEVER commit .env file to version control
# 4. Use strong, randomly generated passwords for all secrets
# ================================================================================

# ======================
# Application Settings
# ======================
APP_NAME=NGSmodule
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false

# Build metadata (for Docker builds)
BUILD_DATE=2024-01-01T00:00:00Z
VCS_REF=main
IMAGE_TAG=latest

# ======================
# Database Configuration
# ======================
# PostgreSQL Database
POSTGRES_USER=ngsmodule
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD_min_32_chars
POSTGRES_DB=ngsmodule
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Full database URL (used by backend)
# DATABASE_URL=postgresql://ngsmodule:PASSWORD@postgres:5432/ngsmodule

# ======================
# Redis Configuration
# ======================
REDIS_PASSWORD=CHANGE_THIS_TO_STRONG_REDIS_PASSWORD_min_32_chars
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Full Redis URL (used by backend and Celery)
# REDIS_URL=redis://:PASSWORD@redis:6379/0

# ======================
# MinIO Object Storage
# ======================
MINIO_ROOT_USER=CHANGE_THIS_MINIO_ROOT_USER
MINIO_ROOT_PASSWORD=CHANGE_THIS_TO_STRONG_MINIO_PASSWORD_min_32_chars
MINIO_BROWSER=on
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ======================
# Security & Authentication
# ======================
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_TO_64_CHAR_HEX_STRING_use_openssl_rand_hex_32
JWT_SECRET_KEY=CHANGE_THIS_TO_64_CHAR_HEX_STRING_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Settings
# Add your production domain(s) here
BACKEND_CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://api.yourdomain.com

# ======================
# Frontend Configuration
# ======================
# Update with your actual production domain
VITE_API_URL=https://api.yourdomain.com/api/v1
VITE_WS_URL=wss://api.yourdomain.com/ws

# Alternative: If using reverse proxy on same domain
# VITE_API_URL=https://yourdomain.com/api/v1
# VITE_WS_URL=wss://yourdomain.com/ws

# ======================
# Server Ports
# ======================
HTTP_PORT=80
HTTPS_PORT=443
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ======================
# Performance & Scaling
# ======================
# Uvicorn workers (CPU cores * 2 + 1)
UVICORN_WORKERS=4

# Celery workers and concurrency
CELERY_WORKERS=2
CELERY_CONCURRENCY=4

# ======================
# Logging Configuration
# ======================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/app/logs/app.log

# ======================
# Email Configuration (Optional)
# ======================
# SMTP settings for notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=NGSmodule
SMTP_TLS=true

# ======================
# Storage Configuration
# ======================
STORAGE_PATH=/data/storage
UPLOAD_PATH=/data/uploads
MAX_UPLOAD_SIZE=524288000  # 500MB in bytes
ALLOWED_EXTENSIONS=fastq,fq,fastq.gz,fq.gz,bam,sam,vcf,csv,txt,bed,gtf,gff

# ======================
# Monitoring & Observability
# ======================
# Sentry for error tracking (Optional)
SENTRY_DSN=

# Enable metrics endpoint
ENABLE_METRICS=true
METRICS_PORT=9090

# Flower (Celery monitoring) credentials
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_THIS_FLOWER_PASSWORD_min_16_chars

# ======================
# Backup Configuration
# ======================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM UTC
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backups

# ======================
# SSL/TLS Configuration
# ======================
# Path to SSL certificates (for Nginx)
SSL_CERTIFICATE_PATH=/etc/nginx/ssl/cert.pem
SSL_CERTIFICATE_KEY_PATH=/etc/nginx/ssl/key.pem

# Let's Encrypt settings (if using certbot)
LETSENCRYPT_EMAIL=admin@yourdomain.com
LETSENCRYPT_DOMAIN=yourdomain.com

# ======================
# Feature Flags (Optional)
# ======================
# Enable/disable features
ENABLE_REGISTRATION=true
ENABLE_AI_FEATURES=true
ENABLE_FILE_UPLOAD=true
ENABLE_NOTIFICATIONS=true
ENABLE_WEBSOCKET=true

# ======================
# Rate Limiting
# ======================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_API=100/second
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_UPLOAD=10/minute

# ======================
# Session Configuration
# ======================
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_MAX_AGE=1209600  # 14 days

# ======================
# Development/Debug (Keep false in production)
# ======================
# NEVER set these to true in production
# DEBUG=false
# RELOAD=false
# TESTING=false

# ======================
# Database Connection Pool
# ======================
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ======================
# External Services (Optional)
# ======================
# AWS S3 (if using instead of MinIO)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1

# Google Cloud Storage (Optional)
# GCS_BUCKET=
# GCS_CREDENTIALS_FILE=/path/to/credentials.json

# ======================
# Custom NGS Pipeline Configuration
# ======================
NGS_PIPELINE_DIR=/app/NGSmodule
NGS_WORK_DIR=/data/ngsmodule_work
NGS_RESULT_DIR=/data/ngsmodule_results
NGS_MAX_CONCURRENT_JOBS=4
NGS_JOB_TIMEOUT=86400  # 24 hours in seconds

# ======================
# Timezone
# ======================
TZ=UTC  # Change to your timezone (e.g., Asia/Shanghai, America/New_York)

# ================================================================================
# DEPLOYMENT CHECKLIST
# ================================================================================
# Before deploying to production, ensure you have:
#
# [ ] Generated strong random passwords for all *_PASSWORD variables
# [ ] Generated SECRET_KEY and JWT_SECRET_KEY using: openssl rand -hex 32
# [ ] Updated all domain names (yourdomain.com) to your actual domain
# [ ] Configured SSL certificates in ./ssl/ directory
# [ ] Set up DNS records pointing to your server
# [ ] Configured firewall rules (allow 80, 443; block 5432, 6379, 9000, etc.)
# [ ] Set up backup strategy and test restore procedure
# [ ] Configured monitoring and alerting (optional but recommended)
# [ ] Reviewed and adjusted rate limits based on expected traffic
# [ ] Set up log rotation and retention policies
# [ ] Tested email configuration (if using notifications)
# [ ] Configured proper file permissions on .env file (chmod 600 .env)
# [ ] Set POSTGRES_PASSWORD, REDIS_PASSWORD, and other secrets via secure means
# [ ] Created backups directory: mkdir -p ./backups/postgres
# [ ] Created SSL directory: mkdir -p ./ssl
# [ ] Verified all required volumes are properly mounted
# [ ] Run security audit: docker scout cve (if available)
# [ ] Test deployment in staging environment first
# [ ] Set up health check monitoring
# [ ] Configure log aggregation (optional but recommended)
#
# ================================================================================
# QUICK START COMMANDS
# ================================================================================
#
# 1. Generate secrets:
#    openssl rand -hex 32  # Run twice for SECRET_KEY and JWT_SECRET_KEY
#
# 2. Create required directories:
#    mkdir -p backups/postgres ssl logs
#
# 3. Set proper permissions:
#    chmod 600 .env
#    chmod 700 backups ssl
#
# 4. Build and start services:
#    docker-compose -f docker-compose.prod.yml up -d
#
# 5. View logs:
#    docker-compose -f docker-compose.prod.yml logs -f
#
# 6. Check health:
#    docker-compose -f docker-compose.prod.yml ps
#    curl http://localhost/api/health
#
# 7. Stop services:
#    docker-compose -f docker-compose.prod.yml down
#
# 8. Backup database:
#    docker-compose -f docker-compose.prod.yml exec postgres pg_dump -U ngsmodule ngsmodule > backup.sql
#
# ================================================================================
